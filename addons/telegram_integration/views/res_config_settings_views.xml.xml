<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.telegram</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@id='integration_settings']" position="inside">
                <div class="col-12 col-lg-6 o_setting_box" id="telegram_settings">
                    <div class="o_setting_left_pane">
                        <field name="module_telegram_integration"/>
                    </div>
                    <div class="o_setting_right_pane">
                        <label for="module_telegram_integration" string="Telegram Integration"/>
                        <div class="text-muted">
                            Connect your ERP with Telegram bot.
                            Send automated notifications, handle customer queries,
                            and manage orders via Telegram.
                        </div>
                        <div class="content-group" attrs="{'invisible': [('module_telegram_integration', '=', False)]}">
                            <div class="mt16">
                                <button name="%(telegram.action_telegram_bot)d" 
                                        type="action" 
                                        string="Configure Telegram Bots" 
                                        class="btn btn-primary"/>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>